backend = "glx";

vsync = true;


shadows = true;
shadow-radius = 0.7;
shadow-opacity = 0.5;
shadow-offset-x = -7;
shadow-offset-y = -7;

shadow-exclude [
	"class_g: 'i3bar'"
];


fading = true;
fade-delta = 5;
fade-in-step = 0.5;
fade-out-step = 0.5;

fade-exclude [
	"class_g: 'rofi'"
];


active-opacity = 1;
inactive-opacity = 0.97;
frame-opacity = 1;
inactive-opacity-override = false;


opacity-rules = [
	
	"95:class_g = 'Alacritty && !focused'",
	"98:class_g = 'Alacritty && focused'",

	"97:class_g = 'rofi'",

	"100:class_g = 'firefox'",

	"97:class_g = 'Thunar'"

];


#blur-backgroud = true;
#blur-method = "Kawase";
#blur-strenght = 5;

#corner-raduis = 5;
#rounded-corners-exclude = [
#	"'class_g' = 'Polybar'",
#	"'class_g'= 'i3bar'"

#];

opacity-exclude = [
	"class_g = 'Polybar'",
	"class_g = 'i3bar'",
	"class_g = 'Dunst'"
];

use-damage = true;

unredir-if-possible = true;
